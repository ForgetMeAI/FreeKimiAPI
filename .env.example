PORT=3271
CFBT_BASE_URL=https://cfbt.ccwu.cc/v1
CFBT_MODEL=@cf/moonshotai/kimi-k2.6
CFBT_MAX_TOKENS_DEFAULT=1024
CFBT_TIMEOUT_MS=60000
CFBT_RETRIES=4
CFBT_RETRY_BASE_MS=700
CFBT_CIRCUIT_BREAKER_FAILURES=8
CFBT_CIRCUIT_BREAKER_MS=30000
# round_robin | random. Uses normal browser-compatible headers for reliability; not an anti-bot bypass.
CFBT_CLIENT_PROFILE_MODE=round_robin
# Optional JSON array: [{"name":"chrome-macos","userAgent":"...","acceptLanguage":"en-US,en;q=0.9"}]
# CFBT_CLIENT_PROFILES_JSON=
# Set to 1 only for debugging request paths.
CFBT_LOG_REQUESTS=0
